{
  "name": "pokemmo-items-prices",
  "version": "1.1.0",
  "description": "Get data on current items listings in the PokeMMO GTL",
  "author": "Dogatsuj",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && cpy \"src/data/**/*\" dist/data"
  },
  "devDependencies": {
    "cpy-cli": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.2"
  }
}
